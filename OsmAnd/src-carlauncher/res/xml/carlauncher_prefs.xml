<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- GÖRÜNÜM - GENEL -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_appearance_general"
        android:title="@string/car_pref_title_appearance_general"
        app:icon="@android:drawable/ic_menu_view"
        android:iconSpaceReserved="true">

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_status_bar"
            android:title="@string/car_pref_title_status_bar"
            android:summary="@string/car_pref_summary_status_bar"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_dark_theme"
            android:title="@string/car_pref_title_dark_theme"
            android:summary="@string/car_pref_summary_dark_theme"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

        <androidx.preference.ListPreference
            android:key="car_launcher_language"
            android:title="@string/car_pref_language_title"
            android:summary="@string/car_pref_language_desc"
            app:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_floating_button"
            android:title="@string/car_pref_title_floating_button"
            android:summary="@string/car_pref_summary_floating_button"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_floating_button_force_gps"
            android:title="@string/car_floating_button_force_gps"
            android:summary="@string/car_floating_button_force_gps_desc"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <androidx.preference.SeekBarPreference
            android:key="car_launcher_floating_button_size"
            android:title="@string/car_pref_title_floating_button_size"
            android:summary="@string/car_pref_summary_floating_button_size"
            android:defaultValue="86"
            android:max="140"
            app:min="50"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false" />

        <androidx.preference.ListPreference
            android:key="car_launcher_night_dim_mode"
            android:title="@string/car_pref_title_night_dim_mode"
            android:summary="%s"
            android:entries="@array/night_dim_mode_entries"
            android:entryValues="@array/night_dim_mode_values"
            android:defaultValue="osmand"
            app:iconSpaceReserved="false" />

        <androidx.preference.SeekBarPreference
            android:key="car_launcher_parallax_intensity"
            android:title="@string/car_pref_title_parallax_intensity"
            android:summary="@string/car_pref_summary_parallax_intensity"
            android:defaultValue="20"
            android:max="50"
            app:min="0"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false" />

        <androidx.preference.ListPreference
            android:key="car_launcher_background_style"
            android:title="@string/car_pref_title_background_style"
            android:summary="%s"
            android:entries="@array/background_style_entries"
            android:entryValues="@array/background_style_values"
            android:defaultValue="modern"
            app:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_pip_mode"
            android:title="@string/car_pref_title_pip_mode"
            android:summary="@string/car_pref_summary_pip_mode"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- GÖRÜNÜM - DİKEY EKRAN -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_appearance_portrait"
        android:title="@string/car_pref_title_appearance_portrait"
        app:icon="@android:drawable/ic_menu_crop"
        android:iconSpaceReserved="true">

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_portrait_map_only"
            android:title="@string/car_pref_title_portrait_map_only"
            android:summary="@string/car_pref_summary_portrait_map_only"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <androidx.preference.ListPreference
            android:key="car_launcher_portrait_expansion"
            android:title="@string/car_pref_title_portrait_expansion"
            android:summary="%s"
            android:entries="@array/portrait_expansion_entries"
            android:entryValues="@array/portrait_expansion_values"
            android:defaultValue="expand_up"
            app:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- GÖRÜNÜM - YATAY EKRAN -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_appearance_landscape"
        android:title="@string/car_pref_title_appearance_landscape"
        app:icon="@android:drawable/ic_menu_gallery"
        android:iconSpaceReserved="true">

        <androidx.preference.ListPreference
            android:key="widget_panel_position"
            android:title="@string/car_pref_title_widget_panel_position"
            android:summary="%s"
            android:entries="@array/widget_panel_position_entries"
            android:entryValues="@array/widget_panel_position_values"
            android:defaultValue="left"
            app:iconSpaceReserved="false" />

        <androidx.preference.ListPreference
            android:key="car_launcher_landscape_expansion"
            android:title="@string/car_pref_title_landscape_expansion"
            android:summary="%s"
            android:entries="@array/landscape_expansion_entries"
            android:entryValues="@array/landscape_expansion_values"
            android:defaultValue="expand_right"
            app:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- MÜZİK AYARLARI -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_music"
        android:title="@string/car_pref_title_music"
        app:icon="@android:drawable/ic_media_play"
        android:iconSpaceReserved="true">

        <androidx.preference.Preference
            android:key="car_launcher_music_app"
            android:title="@string/car_pref_title_music_app"
            android:summary="@string/car_pref_summary_music_app"
            app:iconSpaceReserved="false" />

        <androidx.preference.ListPreference
            android:key="car_launcher_visualizer_type_small"
            android:title="@string/car_pref_title_visualizer_type_small"
            android:summary="%s"
            android:entries="@array/visualizer_type_entries"
            android:entryValues="@array/visualizer_type_values"
            android:defaultValue="2"
            app:iconSpaceReserved="false" />

        <androidx.preference.ListPreference
            android:key="car_launcher_visualizer_type_large"
            android:title="@string/car_pref_title_visualizer_type_large"
            android:summary="%s"
            android:entries="@array/visualizer_type_entries"
            android:entryValues="@array/visualizer_type_values"
            android:defaultValue="4"
            app:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_auto_play_music"
            android:title="@string/car_pref_title_auto_play_music"
            android:summary="@string/car_pref_summary_auto_play_music"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_ambiance_visualizer"
            android:title="@string/car_pref_title_ambiance_visualizer"
            android:summary="@string/car_pref_summary_ambiance_visualizer"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

        <androidx.preference.Preference
            android:key="car_launcher_equalizer"
            android:title="@string/car_pref_title_equalizer"
            android:summary="@string/car_pref_summary_equalizer"
            app:iconSpaceReserved="false" />

        <androidx.preference.Preference
            android:key="car_launcher_scan_music"
            android:title="@string/car_pref_title_scan_music"
            android:summary="@string/car_pref_summary_scan_music"
            app:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- HAVA DURUMU AYARLARI -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_weather"
        android:title="@string/car_pref_title_weather"
        app:icon="@android:drawable/ic_menu_my_calendar"
        android:iconSpaceReserved="true">

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_weather_enabled"
            android:title="@string/car_pref_title_weather_enabled"
            android:summary="@string/car_pref_summary_weather_enabled"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- OTOMATİK BAŞLATMA -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_autolaunch"
        android:title="@string/car_pref_title_autolaunch"
        app:icon="@android:drawable/ic_menu_recent_history"
        android:iconSpaceReserved="true">

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_auto_start_on_boot"
            android:title="@string/car_pref_title_auto_start_on_boot"
            android:summary="@string/car_pref_summary_auto_start_on_boot"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="autolaunch_enable_1"
            android:title="@string/car_pref_title_app1"
            android:summary="@string/car_pref_summary_click_to_select"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="autolaunch_enable_2"
            android:title="@string/car_pref_title_app2"
            android:summary="@string/car_pref_summary_click_to_select"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="autolaunch_enable_3"
            android:title="@string/car_pref_title_app3"
            android:summary="@string/car_pref_summary_click_to_select"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- YEDEKLEME -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_backup"
        android:title="@string/car_pref_title_backup"
        app:icon="@android:drawable/ic_menu_save"
        android:iconSpaceReserved="true">

        <androidx.preference.Preference
            android:key="action_backup_export"
            android:title="@string/car_pref_title_backup_export"
            android:summary="@string/car_pref_summary_backup_export"
            app:iconSpaceReserved="false" />

        <androidx.preference.Preference
            android:key="action_backup_import"
            android:title="@string/car_pref_title_backup_import"
            android:summary="@string/car_pref_summary_backup_import"
            app:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- DOCK AYARLARI - YATAY EKRAN -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_dock_landscape"
        android:title="@string/car_pref_title_dock_landscape"
        app:icon="@android:drawable/ic_menu_sort_by_size"
        android:iconSpaceReserved="true">

        <androidx.preference.ListPreference
            android:key="car_launcher_dock_position"
            android:title="@string/car_pref_title_dock_position"
            android:summary="%s"
            android:entries="@array/dock_position_entries"
            android:entryValues="@array/dock_position_values"
            android:defaultValue="bottom"
            app:iconSpaceReserved="false" />

        <androidx.preference.SeekBarPreference
            android:key="car_launcher_dock_size"
            android:title="@string/car_pref_title_dock_size"
            android:summary="@string/car_pref_summary_dock_size"
            android:defaultValue="50"
            android:max="100"
            app:min="0"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false" />

        <androidx.preference.SeekBarPreference
            android:key="car_launcher_max_shortcuts"
            android:title="@string/car_pref_title_max_shortcuts"
            android:defaultValue="6"
            android:max="10"
            app:min="3"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false" />

        <androidx.preference.Preference
            android:key="car_launcher_reset_dock"
            android:title="@string/car_pref_title_reset_dock"
            android:summary="@string/car_pref_summary_reset_dock"
            app:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- DOCK AYARLARI - DİKEY EKRAN -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_dock_portrait"
        android:title="@string/car_pref_title_dock_portrait"
        app:icon="@android:drawable/ic_menu_sort_by_size"
        android:iconSpaceReserved="true">

        <androidx.preference.ListPreference
            android:key="car_launcher_dock_position_portrait"
            android:title="@string/car_pref_title_dock_position_portrait"
            android:summary="%s"
            android:entries="@array/dock_position_portrait_entries"
            android:entryValues="@array/dock_position_portrait_values"
            android:defaultValue="bottom"
            app:iconSpaceReserved="false" />

        <androidx.preference.SeekBarPreference
            android:key="car_launcher_dock_size_portrait"
            android:title="@string/car_pref_title_dock_size"
            android:summary="@string/car_pref_summary_dock_size"
            android:defaultValue="50"
            android:max="100"
            app:min="0"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ASİSTAN AYARLARI -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_assistant"
        android:title="@string/car_pref_title_assistant"
        app:icon="@android:drawable/ic_btn_speak_now"
        android:iconSpaceReserved="true">

        <androidx.preference.Preference
            android:key="car_launcher_import_voice_model"
            android:title="@string/car_pref_title_import_voice_model"
            android:summary="@string/car_pref_summary_import_voice_model"
            app:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- HAKKINDA -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_about"
        android:title="@string/car_pref_title_about"
        app:icon="@android:drawable/ic_menu_info_details"
        android:iconSpaceReserved="true">

        <androidx.preference.Preference
            android:key="car_launcher_version"
            android:title="@string/car_pref_title_version"
            android:summary="1.0.0"
            android:selectable="false"
            app:iconSpaceReserved="false" />

        <androidx.preference.Preference
            android:key="car_launcher_check_updates"
            android:title="@string/car_pref_title_check_updates"
            android:summary="@string/car_pref_summary_check_updates"
            app:iconSpaceReserved="false" />

        <androidx.preference.Preference
            android:key="car_launcher_github"
            android:title="@string/car_pref_title_github"
            android:summary="@string/car_pref_summary_github"
            app:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

</androidx.preference.PreferenceScreen>
