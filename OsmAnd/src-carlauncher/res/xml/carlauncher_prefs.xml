<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- GÖRÜNÜM AYARLARI -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_appearance"
        android:title="Görünüm"
        app:icon="@android:drawable/ic_menu_view"
        android:iconSpaceReserved="true">

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_status_bar"
            android:title="Status Bar Göster"
            android:summary="Sistem çubuğunu açıp kapatır"
            android:defaultValue="true"
            android:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_dark_theme"
            android:title="Koyu Tema"
            android:summary="Karanlık arka plan kullan"
            android:defaultValue="true"
            android:iconSpaceReserved="false" />

        <androidx.preference.ListPreference
            android:key="widget_display_mode"
            android:title="Widget Görünüm Modu"
            android:summary="%s"
            android:entries="@array/widget_display_mode_entries"
            android:entryValues="@array/widget_display_mode_values"
            android:defaultValue="0"
            android:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_portrait_map_only"
            android:title="Dikey Ekranda Sadece Harita Goster"
            android:summary="Dikey modda widget paneli ve rihtimi gizler"
            android:defaultValue="false"
            android:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_floating_button"
            android:title="Yuzen Yardimci Buton (Floating Button)"
            android:summary="Ekranda tasinabilir sistem menu butonu gosterir"
            android:defaultValue="false"
            android:iconSpaceReserved="false" />

        <androidx.preference.SeekBarPreference
            android:key="car_launcher_floating_button_size"
            android:title="Yuzen Buton Boyutu"
            android:summary="Ekranda kapladigi alani ayarla"
            android:defaultValue="86"
            android:max="140"
            app:min="50"
            app:showSeekBarValue="true"
            android:iconSpaceReserved="false" />

        <androidx.preference.ListPreference
            android:key="car_launcher_night_dim_mode"
            android:title="Gece Karartma Modu"
            android:summary="%s"
            android:entries="@array/night_dim_mode_entries"
            android:entryValues="@array/night_dim_mode_values"
            android:defaultValue="osmand"
            android:iconSpaceReserved="false" />

        <!-- Premium Kisiklestirme Ayarlari -->
        <androidx.preference.SeekBarPreference
            android:key="car_launcher_parallax_intensity"
            android:title="Parallax Arka Plan Gucu"
            android:summary="ViewPager kaydirilirken arka planin kayma miktarini ayarlar (Varsayilan: %20)"
            android:defaultValue="20"
            android:max="50"
            app:min="0"
            app:showSeekBarValue="true"
            android:iconSpaceReserved="false" />

        <androidx.preference.ListPreference
            android:key="car_launcher_background_style"
            android:title="Parallax Arka Plan Secici"
            android:summary="%s"
            android:entries="@array/background_style_entries"
            android:entryValues="@array/background_style_values"
            android:defaultValue="modern"
            android:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_pip_mode"
            android:title="Yüzen Harita (Picture-in-Picture)"
            android:summary="Arka plana geçildiğinde haritayı yüzen küçük ekran olarak açık tutar"
            android:defaultValue="true"
            android:iconSpaceReserved="false" />

        <androidx.preference.ListPreference
            android:key="widget_panel_position"
            android:title="Büyük Panel Konumu"
            android:summary="%s"
            android:entries="@array/widget_panel_position_entries"
            android:entryValues="@array/widget_panel_position_values"
            android:defaultValue="right"
            android:iconSpaceReserved="false" />

        <androidx.preference.ListPreference
            android:key="car_launcher_expansion_behavior"
            android:title="Büyük Panel Açılış Stratejisi"
            android:summary="%s"
            android:entries="@array/expansion_behavior_entries"
            android:entryValues="@array/expansion_behavior_values"
            android:defaultValue="swap"
            android:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>



    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- MÜZİK AYARLARI -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_music"
        android:title="Müzik"
        app:icon="@android:drawable/ic_media_play"
        android:iconSpaceReserved="true">

        <androidx.preference.Preference
            android:key="car_launcher_music_app"
            android:title="Varsayılan Müzik Uygulaması"
            android:summary="Tıklayarak seçin"
            android:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_auto_play_music"
            android:title="Açılışta Otomatik Oynat"
            android:summary="Uygulama başladığında müziği başlat"
            android:defaultValue="false"
            android:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_ambiance_visualizer"
            android:title="Ambians Görselleştirici"
            android:summary="Müzik görselleştirici renklerini albüm kapağına göre dinamik olarak belirler"
            android:defaultValue="true"
            android:iconSpaceReserved="false" />

        <androidx.preference.Preference
            android:key="car_launcher_equalizer"
            android:title="Equalizer"
            android:summary="Sistem ses ayarlarını aç"
            android:iconSpaceReserved="false" />

        <androidx.preference.Preference
            android:key="car_launcher_scan_music"
            android:title="Muzikleri Yeniden Tara"
            android:summary="Dahili depolama ve USB bellekleri tara"
            android:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- HAVA DURUMU AYARLARI -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_weather"
        android:title="Hava Durumu"
        app:icon="@android:drawable/ic_menu_my_calendar"
        android:iconSpaceReserved="true">

        <androidx.preference.SwitchPreferenceCompat
            android:key="car_launcher_weather_enabled"
            android:title="Hava Durumu Servisi"
            android:summary="Saat widget'ında hava durumu gösterimi"
            android:defaultValue="true"
            android:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- OTOMATİK BAŞLATMA -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_autolaunch"
        android:title="Otomatik Başlatma"
        app:icon="@android:drawable/ic_menu_recent_history"
        android:iconSpaceReserved="true">

        <androidx.preference.SwitchPreferenceCompat
            android:key="autolaunch_enable_1"
            android:title="Uygulama 1"
            android:summary="Seçmek için metne tıklayın"
            android:defaultValue="false"
            android:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="autolaunch_enable_2"
            android:title="Uygulama 2"
            android:summary="Seçmek için metne tıklayın"
            android:defaultValue="false"
            android:iconSpaceReserved="false" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="autolaunch_enable_3"
            android:title="Uygulama 3"
            android:summary="Seçmek için metne tıklayın"
            android:defaultValue="false"
            android:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- YEDEKLEME -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_backup"
        android:title="Yedekle ve Geri Yükle"
        app:icon="@android:drawable/ic_menu_save"
        android:iconSpaceReserved="true">

        <androidx.preference.Preference
            android:key="action_backup_export"
            android:title="Ayarları Dışa Aktar"
            android:summary="Widget düzenini ve ayarları dosyaya kaydet"
            android:iconSpaceReserved="false" />

        <androidx.preference.Preference
            android:key="action_backup_import"
            android:title="Ayarları Geri Yükle"
            android:summary="Dosyadan geri yükle"
            android:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- DOCK AYARLARI -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_dock"
        android:title="Uygulama Dock (Sidebar)"
        app:icon="@android:drawable/ic_menu_sort_by_size"
        android:iconSpaceReserved="true">

        <androidx.preference.ListPreference
            android:key="car_launcher_dock_position"
            android:title="Dock Konumu"
            android:summary="%s"
            android:entries="@array/dock_position_entries"
            android:entryValues="@array/dock_position_values"
            android:defaultValue="bottom"
            android:iconSpaceReserved="false" />

        <androidx.preference.SeekBarPreference
            android:key="car_launcher_dock_size"
            android:title="Dock Boyutu"
            android:summary="0: Küçük, 50: Normal, 100: Büyük"
            android:defaultValue="50"
            android:max="100"
            app:min="0"
            app:showSeekBarValue="true"
            android:iconSpaceReserved="false" />

        <androidx.preference.SeekBarPreference
            android:key="car_launcher_max_shortcuts"
            android:title="Maksimum Kısayol Sayısı"
            android:defaultValue="6"
            android:max="10"
            app:min="3"
            app:showSeekBarValue="true"
            android:iconSpaceReserved="false" />

        <androidx.preference.Preference
            android:key="car_launcher_reset_dock"
            android:title="Dock'u Sıfırla"
            android:summary="Tüm kısayolları kaldır"
            android:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ASİSTAN AYARLARI -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_assistant"
        android:title="Asistan"
        app:icon="@android:drawable/ic_btn_speak_now"
        android:iconSpaceReserved="true">

        <androidx.preference.Preference
            android:key="car_launcher_import_voice_model"
            android:title="Ses Modelini USB/Dosyadan Yukle"
            android:summary="İnternet yoksa USB'den indirdiğiniz zip modelini yükleyin"
            android:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- HAKKINDA -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory
        android:key="category_about"
        android:title="Hakkında"
        app:icon="@android:drawable/ic_menu_info_details"
        android:iconSpaceReserved="true">

        <androidx.preference.Preference
            android:key="car_launcher_version"
            android:title="Versiyon"
            android:summary="1.0.0"
            android:selectable="false"
            android:iconSpaceReserved="false" />

        <androidx.preference.Preference
            android:key="car_launcher_check_updates"
            android:title="Güncellemeleri Denetle"
            android:summary="Yeni bir sürüm olup olmadığını kontrol et"
            android:iconSpaceReserved="false" />

        <androidx.preference.Preference
            android:key="car_launcher_github"
            android:title="GitHub"
            android:summary="Kaynak kodunu görüntüle"
            android:iconSpaceReserved="false" />

    </net.osmand.plus.carlauncher.ui.CarLauncherPreferenceCategory>

</androidx.preference.PreferenceScreen>
