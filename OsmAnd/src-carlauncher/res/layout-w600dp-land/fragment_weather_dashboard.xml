<?xml version="1.0" encoding="utf-8"?>
<!-- Araba Teybi Landscape — 3 Sutunlu Ultra Compact Layout (1280x480) -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6000000"
    android:clickable="true"
    android:focusable="true">

    <!-- HEADER: Location + Close -->
    <LinearLayout
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_location"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Location"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#FFFFFF"
            android:padding="8dp"
            android:scaleType="centerInside"/>
    </LinearLayout>

    <!-- CONTENT: 3 Columns -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp"
        android:baselineAligned="false"
        app:layout_constraintTop_toBottomOf="@id/header_bar"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- COLUMN 1: Current Weather (%30) -->
        <LinearLayout
            android:id="@+id/col_left"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingEnd="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <ImageView
                    android:id="@+id/img_current_icon"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_weather_cloudy"/>

                <TextView
                    android:id="@+id/tv_current_temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24°"
                    android:textColor="#FFFFFF"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_current_condition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cloudy"
                android:textColor="#E0E0E0"
                android:textSize="20sp"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tv_apparent_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Feels 26°"
                android:textColor="#AAAAAA"
                android:textSize="16sp"
                android:layout_marginTop="4dp"/>

            <!-- Detaylar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">
                
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_action_direction" android:tint="#AAAAAA"/>
                    <TextView android:id="@+id/tv_wind" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15.0 km/h" android:textColor="#FFFFFF" android:textSize="14sp" android:layout_marginStart="8dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_weather_rain" android:tint="#AAAAAA"/>
                    <TextView android:id="@+id/tv_rain" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10%" android:textColor="#FFFFFF" android:textSize="14sp" android:layout_marginStart="8dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_action_view" android:tint="#AAAAAA"/>
                    <TextView android:id="@+id/tv_visibility" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10 km" android:textColor="#FFFFFF" android:textSize="14sp" android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Divider 1 -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#33FFFFFF"
            android:layout_marginVertical="8dp"/>

        <!-- COLUMN 2: Hourly & Graph (%45) -->
        <LinearLayout
            android:id="@+id/col_mid"
            android:layout_width="0dp"
            android:layout_weight="1.5"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/lbl_hourly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hourly"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_hourly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"/>

            <net.osmand.plus.carlauncher.widgets.view.TrendGraphView
                android:id="@+id/trend_graph"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>
        </LinearLayout>

        <!-- Divider 2 -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#33FFFFFF"
            android:layout_marginVertical="8dp"/>

        <!-- COLUMN 3: 7-Day Daily (%25) -->
        <LinearLayout
            android:id="@+id/col_right"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="16dp">

            <TextView
                android:id="@+id/lbl_daily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7-Day"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_daily"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
