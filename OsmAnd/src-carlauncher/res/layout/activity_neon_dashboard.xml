<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050A1A"> <!-- Fütüristik Koyu Lacivert/Siyah Arkaplan -->

    <!-- Haritayi yari saydam gormek istersek baska bir katman eklenebilir, simdilik kapali renk -->

    <!-- Kapat (Geri) Butonu -->
    <ImageButton
        android:id="@+id/btn_close"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="#FFFFFF"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ECO MODE silindi -->

    <!-- Neon Hiz Gostergesi -->
    <net.osmand.plus.carlauncher.widgets.view.FuturisticSpeedometerView
        android:id="@+id/futuristic_speed"
        android:layout_width="360dp"
        android:layout_height="360dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Sol Dinamik Data (Yol/Sokak Ismi vs) -->
    <LinearLayout
        android:id="@+id/panel_left"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintEnd_toStartOf="@id/futuristic_speed"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="32dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOCATION"
            android:textColor="#00E5FF"
            android:textSize="10sp"
            android:letterSpacing="0.2"/>
        <TextView
            android:id="@+id/tv_left_metric"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="---"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="24sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Sag Dinamik Data (Rakim/Pusula vs) -->
    <LinearLayout
        android:id="@+id/panel_right"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/futuristic_speed"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ALTITUDE"
            android:textColor="#00E5FF"
            android:textSize="10sp"
            android:letterSpacing="0.2"/>
        <TextView
            android:id="@+id/tv_right_metric"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="---"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="28sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Statik Alt Bilgi silindi -->

</androidx.constraintlayout.widget.ConstraintLayout>
