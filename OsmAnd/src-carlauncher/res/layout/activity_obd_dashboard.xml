<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cl_background_deep"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OBD Dashboard"
        android:textSize="32sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Grafiksel Göstergeler (Yakında)"
        android:textSize="18sp"
        android:textColor="#AAAAAA"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp">

        <net.osmand.plus.carlauncher.widgets.view.GaugeView
            android:id="@+id/gauge_rpm"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <net.osmand.plus.carlauncher.widgets.view.GaugeView
            android:id="@+id/gauge_speed"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />
            
        <net.osmand.plus.carlauncher.widgets.view.GaugeView
            android:id="@+id/gauge_temp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

    </LinearLayout>

</LinearLayout>
