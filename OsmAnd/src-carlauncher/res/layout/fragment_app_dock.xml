<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dock_content_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <!-- 1. App Drawer Button -->
    <ImageButton
        android:id="@+id/btn_app_list"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackgroundBorderless" 
        android:contentDescription="Apps"
        android:padding="14dp"
        android:scaleType="fitCenter"
        android:src="@drawable/dashboard_grid"
        app:tint="@color/cl_primary" />

    <!-- 3. Shortcuts RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/dock_recycler"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:orientation="horizontal" />

    <!-- 4. Mini Music Player -->
    <LinearLayout
        android:id="@+id/mini_music_container"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_drawer_rounded" 
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginEnd="12dp"
        android:minWidth="160dp">

        <ImageView
            android:id="@+id/mini_music_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_media_play"
            app:tint="@color/cl_accent_orange"/>

        <TextView
            android:id="@+id/mini_music_title"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="Muzik"
            android:textColor="@color/cl_text_primary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="marquee"
            android:singleLine="true"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"/>

        <ImageButton
            android:id="@+id/mini_btn_play"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_media_play"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            app:tint="@color/cl_primary"/>

        <ImageButton
            android:id="@+id/mini_btn_next"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_media_next"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            app:tint="@color/cl_text_secondary"/>

    </LinearLayout>

    <!-- 5. Clock + Layout Toggle -->
    <LinearLayout
        android:id="@+id/clock_settings_container"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/dock_clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:00"
            android:textColor="@color/cl_text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"/>

        <ImageButton
            android:id="@+id/btn_layout_toggle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_action_view_as_list"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            app:tint="@color/cl_text_hint"/>

    </LinearLayout>

</LinearLayout>
