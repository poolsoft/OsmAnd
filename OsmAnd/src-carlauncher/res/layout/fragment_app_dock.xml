<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dock_content_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="0dp"
    android:paddingEnd="8dp">

    <!-- 1. App Drawer Button -->
    <ImageButton
        android:id="@+id/btn_app_list"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:background="?attr/selectableItemBackgroundBorderless" 
        android:contentDescription="Apps"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:paddingStart="0dp"
        android:paddingEnd="12dp"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:src="@drawable/dashboard_grid"
        app:tint="@color/cl_primary"
        android:visibility="visible" />

    <!-- 3. Shortcuts RecyclerView (wrap_content ve weight=0 olarak dinamiklestirildi - Turkce karakter yok) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/dock_recycler"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:orientation="horizontal" />

    <!-- 4. Mini Music Player (Kalan boslugu dinamik kaplayacak sekilde weight=1 ve minWidth eklendi - Turkce karakter yok) -->
    <LinearLayout
        android:id="@+id/mini_music_container"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_drawer_rounded" 
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginEnd="8dp"
        android:minWidth="120dp">

        <ImageView
            android:id="@+id/mini_music_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_media_play"
            android:layout_marginStart="2dp"
            app:tint="@color/cl_accent_orange"/>

        <TextView
            android:id="@+id/mini_music_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Muzik"
            android:textColor="@color/cl_text_primary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="marquee"
            android:singleLine="true"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <ImageButton
            android:id="@+id/mini_btn_play"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_media_play"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            app:tint="@color/cl_primary"/>

        <ImageButton
            android:id="@+id/mini_btn_next"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_media_next"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            app:tint="@color/cl_text_secondary"/>

    </LinearLayout>

    <!-- 5. Clock -->
    <LinearLayout
        android:id="@+id/clock_settings_container"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/dock_clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:00"
            android:textColor="@color/cl_text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"/>

    </LinearLayout>

    <!-- Desktop Mode Button -->
    <ImageButton
        android:id="@+id/btn_desktop_mode"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="4dp"
        android:src="@drawable/ic_desktop_mode"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        app:tint="@color/cl_text_hint"/>

    <!-- 6. Layout Toggle (3-dot Menu) -->
    <ImageButton
        android:id="@+id/btn_layout_toggle"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="4dp"
        android:src="@drawable/ic_layout_split"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        app:tint="@color/cl_text_hint"
        android:visibility="gone" />

</LinearLayout>
