<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/unified_panel_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_panel_modern"
    android:clipToOutline="true">

    <!-- Album Kapagi Arka Plan -->
    <ImageView
        android:id="@+id/unified_album_art"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:alpha="0.4"
        android:src="@drawable/bg_default_music_art"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Cam Efekti Arka Plan -->
    <View
        android:id="@+id/unified_glass_layer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#33000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bagimsiz Menu Butonu (Yatay Bar Kaldirildi, Menu Butonu Kardes View Olarak Konumlandirildi - Turkce karakter yok) -->
    <ImageButton
        android:id="@+id/panel_menu_btn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_more_vert"
        android:tint="#FFFFFF"
        android:padding="6dp"
        android:scaleType="centerInside"
        android:contentDescription="Menu"
        android:elevation="8dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Call / Notification Card (Gelen Cagri / Bildirim Alani - Varsayilan GONE - Turkce karakter yok) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_notification"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:padding="12dp"
        android:background="@drawable/bg_card_rounded_dark"
        android:elevation="6dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/notif_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/stat_sys_phone_call"
            app:tint="@color/cl_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/notif_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Gelen Cagri"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/notif_icon"
            app:layout_constraintEnd_toStartOf="@id/btn_notif_close"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/notif_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Ahmet Yilmaz"
            android:textColor="#BBBBBB"
            android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@id/notif_icon"
            app:layout_constraintEnd_toStartOf="@id/btn_notif_close"
            app:layout_constraintTop_toBottomOf="@id/notif_title"/>

        <ImageButton
            android:id="@+id/btn_notif_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#FFFFFF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Music Player Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/music_area"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?selectableItemBackground"
        app:layout_constraintTop_toBottomOf="@id/card_notification"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Mini Album Cover inside panel -->
        <ImageView
            android:id="@+id/music_mini_art"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_default_album_art"
            android:tint="#88FFFFFF"
            android:background="@drawable/bg_track_art_placeholder"
            android:padding="12dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Track Title -->
        <TextView
            android:id="@+id/music_track_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="Parca Adi"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/music_mini_art"/>

        <!-- Artist -->
        <TextView
            android:id="@+id/music_track_artist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Sanatci"
            android:textColor="#BBBBBB"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/music_track_title"/>

        <!-- Visualizer dancing bars -->
        <net.osmand.plus.carlauncher.widgets.MusicVisualizerView
            android:id="@+id/music_visualizer"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/music_track_artist"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Controls -->
        <LinearLayout
            android:id="@+id/music_controls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/music_visualizer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/music_btn_prev"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/music_btn_play"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="20dp"
                android:background="@drawable/bg_circle_button"
                android:backgroundTint="@color/cl_primary"
                android:src="@android:drawable/ic_media_play"
                app:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/music_btn_next"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_next"
                app:tint="#FFFFFF" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
