<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_panel_modern"> 
    <!-- Note: bg_panel_modern or fallback color handled in code usually, but valid to put here if resource exists -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/widget_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="48dp" />

    <!-- Floating 3-Dot Menu Button (Top Right) -->
    <ImageButton
        android:id="@+id/btn_widget_menu"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="end|top"
        android:layout_margin="4dp"
        android:src="@drawable/ic_overflow_menu_white"
        android:background="?selectableItemBackgroundBorderless"
        android:scaleType="center"
        android:contentDescription="Menu" />

</FrameLayout>
