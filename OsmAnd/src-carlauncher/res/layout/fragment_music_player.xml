<?xml version="1.0" encoding="utf-8"?>
<!-- Modern Music Player - Split Layout with Left Side Dock -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@android:color/transparent"
    android:clickable="true"
    android:focusable="true">

    <!-- Main Content Container -->
    <LinearLayout
        android:id="@+id/main_content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- LEFT PANEL: PLAYER CONTROLS (40%) -->
        <FrameLayout
            android:id="@+id/player_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:background="@android:color/transparent">

            <!-- 1. Full Ambient Blurred Background -->
            <ImageView
                android:id="@+id/now_playing_art_blur"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_default_music_art"
                android:alpha="0.25"/>

            <!-- 2. Dark Overlay Gradient (Bottom to Top) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_music_player_overlay_gradient"/>

            <!-- 2.5 Visualizer (Above BG/Overlay, Behind Content) -->
            <net.osmand.plus.carlauncher.widgets.MusicVisualizerView
                android:id="@+id/player_visualizer"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_gravity="bottom"
                android:alpha="0.4" />

            <!-- 3. Side Dock ve Player Content Sarmalayici -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <!-- SOL DIKEY DOCK: HIZLI ERISIM PANELI -->
                <LinearLayout
                    android:id="@+id/music_side_dock"
                    android:layout_width="60dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:background="#20000000"
                    android:gravity="center_horizontal"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:elevation="2dp">

                    <!-- Kapat Butonu (Sol Ust Kose) -->
                    <ImageButton
                        android:id="@+id/btn_close"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:tint="#FFFFFF"
                        android:contentDescription="Kapat"
                        android:padding="10dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Uygulama Secici (Aktif uygulama simgesi, tiklayınca picker acılacak) -->
                    <FrameLayout
                        android:id="@+id/app_selector_launch"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_circle_translucent_white"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginBottom="16dp">
                        
                        <ImageView
                            android:id="@+id/app_icon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_media_play"/>
                    </FrameLayout>

                    <!-- Playlist Butonu -->
                    <ImageButton
                        android:id="@+id/btn_dock_playlist"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@android:drawable/ic_menu_agenda"
                        android:tint="#FFFFFF"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Calma Listesi"
                        android:scaleType="centerInside"
                        android:padding="10dp" />

                    <!-- Alttaki Bosluk -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                </LinearLayout>

                <!-- ConstraintLayout ile dikey sigmasi optimize edilmis icerik -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1">

                    <!-- Floating Cover Art Card Container -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_album_art"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="8dp"
                        app:cardBackgroundColor="#1AFFFFFF"
                        android:foreground="?android:attr/selectableItemBackground"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/player_info_container"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="4dp">

                        <ImageView
                            android:id="@+id/now_playing_art"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_default_album_art"
                            android:padding="20dp"
                            android:tint="#88FFFFFF"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Info (Now in middle/bottom) -->
                    <LinearLayout
                        android:id="@+id/player_info_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        app:layout_constraintTop_toBottomOf="@id/card_album_art"
                        app:layout_constraintBottom_toTopOf="@id/player_progress_container"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <TextView
                            android:id="@+id/now_playing_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="marquee"
                            android:gravity="center"
                            android:singleLine="true"
                            android:text="Parca Adi"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:shadowColor="#000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="4"/>

                        <TextView
                            android:id="@+id/now_playing_artist"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:singleLine="true"
                            android:text="Sanatci"
                            android:textColor="#DDDDDD"
                            android:textSize="13sp"
                            android:shadowColor="#000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="2"/>
                    </LinearLayout>

                    <!-- Metadata & Seekbar -->
                    <LinearLayout
                        android:id="@+id/player_progress_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingBottom="8dp"
                        app:layout_constraintTop_toBottomOf="@id/player_info_container"
                        app:layout_constraintBottom_toTopOf="@id/btn_play"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="4dp">
                            <TextView
                                android:id="@+id/time_current"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0:00"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:shadowColor="#000000"
                                android:shadowDx="1"
                                android:shadowDy="1"
                                android:shadowRadius="2"/>
                            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                            <TextView
                                android:id="@+id/time_total"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0:00"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:shadowColor="#000000"
                                android:shadowDx="1"
                                android:shadowDy="1"
                                android:shadowRadius="2"/>
                        </LinearLayout>

                        <SeekBar
                            android:id="@+id/seekbar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="#00FFFF"
                            android:thumbTint="#00FFFF" />
                    </LinearLayout>

                    <!-- Controls (ConstraintLayout Chain ile Duzlestirildi) -->
                    <ImageButton
                        android:id="@+id/btn_shuffle"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_music_shuffle"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:tint="#FFFFFF"
                        android:scaleType="centerInside"
                        android:padding="6dp"
                        android:contentDescription="Karistir"
                        app:layout_constraintHorizontal_chainStyle="spread"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/btn_prev"
                        app:layout_constraintTop_toTopOf="@id/btn_play"
                        app:layout_constraintBottom_toBottomOf="@id/btn_play"/>

                    <ImageButton
                        android:id="@+id/btn_prev"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_music_prev"
                        android:background="@drawable/bg_circle_translucent_white"
                        android:tint="#FFFFFF"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        android:contentDescription="Onceki"
                        app:layout_constraintStart_toEndOf="@id/btn_shuffle"
                        app:layout_constraintEnd_toStartOf="@id/btn_play"
                        app:layout_constraintTop_toTopOf="@id/btn_play"
                        app:layout_constraintBottom_toBottomOf="@id/btn_play"/>

                    <ImageButton
                        android:id="@+id/btn_play"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_music_play"
                        android:background="@drawable/bg_circle_cyan"
                        android:tint="#000000"
                        android:padding="14dp"
                        android:contentDescription="Oynat"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/btn_next"
                        app:layout_constraintStart_toEndOf="@id/btn_prev"
                        app:layout_constraintTop_toBottomOf="@id/player_progress_container"
                        android:layout_marginBottom="12dp"/>

                    <ImageButton
                        android:id="@+id/btn_next"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_music_next"
                        android:background="@drawable/bg_circle_translucent_white"
                        android:tint="#FFFFFF"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        android:contentDescription="Sonraki"
                        app:layout_constraintStart_toEndOf="@id/btn_play"
                        app:layout_constraintEnd_toStartOf="@id/btn_repeat"
                        app:layout_constraintTop_toTopOf="@id/btn_play"
                        app:layout_constraintBottom_toBottomOf="@id/btn_play"/>

                    <ImageButton
                        android:id="@+id/btn_repeat"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_music_repeat"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:tint="#FFFFFF"
                        android:scaleType="centerInside"
                        android:padding="6dp"
                        android:contentDescription="Tekrar"
                        app:layout_constraintStart_toEndOf="@id/btn_next"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/btn_play"
                        app:layout_constraintBottom_toBottomOf="@id/btn_play"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- RIGHT PANEL: TRACK LIST (60%) -->
        <LinearLayout
            android:id="@+id/track_list_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="6"
            android:orientation="vertical"
            android:background="@android:color/transparent"
            android:padding="8dp">

            <!-- Hybrid Tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_rounded_black"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tab_all_tracks"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Tum Sarkilar"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="?android:attr/selectableItemBackground"/>
                
                <View android:layout_width="1dp" android:layout_height="24dp" android:background="#444444"/>

                <TextView
                    android:id="@+id/tab_recent"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Son Calinan"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="?android:attr/selectableItemBackground"/>

                <View android:layout_width="1dp" android:layout_height="24dp" android:background="#444444"/>

                <!-- Playlist Tab with Spinner -->
                <LinearLayout
                    android:id="@+id/tab_playlists_container"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.5"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="?android:attr/selectableItemBackground"
                    android:paddingStart="8dp">
                    
                    <TextView
                        android:id="@+id/tab_playlist_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Listeler: "
                        android:textColor="#888888"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <Spinner
                        android:id="@+id/playlist_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:spinnerMode="dropdown"/>
                </LinearLayout>
            </LinearLayout>
            
            <!-- Search Bar -->
            <EditText
                android:id="@+id/search_input"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/bg_widget_card"
                android:hint="Ara..."
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:textSize="14sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:singleLine="true"
                android:imeOptions="actionSearch"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawableTint="#888888"
                android:drawablePadding="8dp"
                android:layout_marginBottom="8dp"/>

            <!-- List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/music_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scrollbars="vertical"
                android:clipToPadding="false"
                android:paddingBottom="16dp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
