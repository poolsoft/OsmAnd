<?xml version="1.0" encoding="utf-8"?>
<!-- Modern Music Player - Split Layout with Left Side Dock -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@android:color/transparent"
    android:clickable="true"
    android:focusable="true">

    <!-- SOL DIKEY DOCK: HIZLI ERISIM PANELI -->
    <LinearLayout
        android:id="@+id/music_side_dock"
        android:layout_width="60dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#E6121212"
        android:gravity="center_horizontal"
        android:paddingVertical="20dp"
        android:elevation="8dp">

        <!-- Player Panelini Acip Kapatan Buton -->
        <ImageButton
            android:id="@+id/btn_dock_player"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_media_play"
            android:tint="#00FFFF"
            android:background="@drawable/bg_circle_translucent_white"
            android:contentDescription="Oynatici"
            android:scaleType="centerInside"
            android:padding="10dp" />

        <!-- Playlist Panelini Acip Kapatan Buton -->
        <ImageButton
            android:id="@+id/btn_dock_playlist"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="20dp"
            android:src="@android:drawable/ic_menu_agenda"
            android:tint="#FFFFFF"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Calma Listesi"
            android:scaleType="centerInside"
            android:padding="10dp" />

    </LinearLayout>

    <!-- Main Content Container -->
    <LinearLayout
        android:id="@+id/main_content_container"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- LEFT PANEL: PLAYER CONTROLS (40%) -->
        <FrameLayout
            android:id="@+id/player_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:background="@android:color/transparent">

            <!-- 1. Full Ambient Blurred Background -->
            <ImageView
                android:id="@+id/now_playing_art_blur"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_default_music_art"
                android:alpha="0.25"/>

            <!-- 2. Dark Overlay Gradient (Bottom to Top) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_music_player_overlay_gradient"/>

            <!-- 2.5 Visualizer (Above BG/Overlay, Behind Content) -->
            <net.osmand.plus.carlauncher.widgets.MusicVisualizerView
                android:id="@+id/player_visualizer"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_gravity="bottom"
                android:alpha="0.4" />

            <!-- 3. Content (ConstraintLayout ile optimize edildi - Hiyerarsi Duzlestirildi) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- App Selector / Header -->
                <LinearLayout
                    android:id="@+id/player_header"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="#40000000"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageButton
                        android:id="@+id/btn_close"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:tint="#FFFFFF"
                        android:contentDescription="Kapat"
                        android:layout_marginEnd="12dp" />

                    <!-- Selector Area -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- 1. Launch App Area (Icon + Name) -->
                        <LinearLayout
                            android:id="@+id/app_selector_launch"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center_vertical"
                            android:background="?android:attr/selectableItemBackground"
                            android:paddingHorizontal="8dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:id="@+id/app_icon"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@android:drawable/ic_media_play"/>

                            <TextView
                                 android:id="@+id/app_name"
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="Muzik Kaynagi"
                                 android:textColor="#FFFFFF"
                                 android:textSize="16sp"
                                 android:textStyle="bold"
                                 android:shadowColor="#000000"
                                 android:shadowDx="1"
                                 android:shadowDy="1"
                                 android:shadowRadius="2"
                                 android:layout_marginStart="12dp"/>
                        </LinearLayout>

                        <!-- 2. Picker Arrow -->
                        <ImageView
                             android:id="@+id/app_selector_arrow"
                             android:layout_width="48dp"
                             android:layout_height="match_parent"
                             android:src="@android:drawable/arrow_down_float"
                             android:tint="#FFFFFF"
                             android:scaleType="centerInside"
                             android:background="?android:attr/selectableItemBackgroundBorderless"
                             android:clickable="true"
                             android:focusable="true"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Floating Cover Art Card Container -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_album_art"
                    android:layout_width="165dp"
                    android:layout_height="165dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="12dp"
                    app:cardBackgroundColor="#1AFFFFFF"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:layout_constraintTop_toBottomOf="@id/player_header"
                    app:layout_constraintBottom_toTopOf="@id/player_info_container"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp">

                    <ImageView
                        android:id="@+id/now_playing_art"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_default_album_art"
                        android:padding="32dp"
                        android:tint="#88FFFFFF"/>
                </androidx.cardview.widget.CardView>

                <!-- Info (Now in middle/bottom) -->
                <LinearLayout
                    android:id="@+id/player_info_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    app:layout_constraintTop_toBottomOf="@id/card_album_art"
                    app:layout_constraintBottom_toTopOf="@id/player_progress_container"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:id="@+id/now_playing_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="marquee"
                        android:gravity="center"
                        android:singleLine="true"
                        android:text="Parca Adi"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:shadowColor="#000000"
                        android:shadowDx="1"
                        android:shadowDy="1"
                        android:shadowRadius="4"/>

                    <TextView
                        android:id="@+id/now_playing_artist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:singleLine="true"
                        android:text="Sanatci"
                        android:textColor="#DDDDDD"
                        android:textSize="14sp"
                        android:shadowColor="#000000"
                        android:shadowDx="1"
                        android:shadowDy="1"
                        android:shadowRadius="2"/>
                </LinearLayout>

                <!-- Metadata & Seekbar -->
                <LinearLayout
                    android:id="@+id/player_progress_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingBottom="16dp"
                    app:layout_constraintTop_toBottomOf="@id/player_info_container"
                    app:layout_constraintBottom_toTopOf="@id/btn_play"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:id="@+id/time_current"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0:00"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:shadowColor="#000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="2"/>
                        <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                        <TextView
                            android:id="@+id/time_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0:00"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:shadowColor="#000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="2"/>
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekbar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#00FFFF"
                        android:thumbTint="#00FFFF" />
                </LinearLayout>

                <!-- Controls (ConstraintLayout Chain ile Duzlestirildi, Space elemanlari kaldirildi) -->
                <ImageButton
                    android:id="@+id/btn_shuffle"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_music_shuffle"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF"
                    android:scaleType="centerInside"
                    android:padding="6dp"
                    android:contentDescription="Karistir"
                    app:layout_constraintHorizontal_chainStyle="spread"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btn_prev"
                    app:layout_constraintTop_toTopOf="@id/btn_play"
                    app:layout_constraintBottom_toBottomOf="@id/btn_play"/>

                <ImageButton
                    android:id="@+id/btn_prev"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_music_prev"
                    android:background="@drawable/bg_circle_translucent_white"
                    android:tint="#FFFFFF"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:contentDescription="Onceki"
                    app:layout_constraintStart_toEndOf="@id/btn_shuffle"
                    app:layout_constraintEnd_toStartOf="@id/btn_play"
                    app:layout_constraintTop_toTopOf="@id/btn_play"
                    app:layout_constraintBottom_toBottomOf="@id/btn_play"/>

                <ImageButton
                    android:id="@+id/btn_play"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_music_play"
                    android:background="@drawable/bg_circle_cyan"
                    android:tint="#000000"
                    android:padding="14dp"
                    android:contentDescription="Oynat"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btn_next"
                    app:layout_constraintStart_toEndOf="@id/btn_prev"
                    app:layout_constraintTop_toBottomOf="@id/player_progress_container"
                    android:layout_marginBottom="32dp"/>

                <ImageButton
                    android:id="@+id/btn_next"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_music_next"
                    android:background="@drawable/bg_circle_translucent_white"
                    android:tint="#FFFFFF"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:contentDescription="Sonraki"
                    app:layout_constraintStart_toEndOf="@id/btn_play"
                    app:layout_constraintEnd_toStartOf="@id/btn_repeat"
                    app:layout_constraintTop_toTopOf="@id/btn_play"
                    app:layout_constraintBottom_toBottomOf="@id/btn_play"/>

                <ImageButton
                    android:id="@+id/btn_repeat"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_music_repeat"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF"
                    android:scaleType="centerInside"
                    android:padding="6dp"
                    android:contentDescription="Tekrar"
                    app:layout_constraintStart_toEndOf="@id/btn_next"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/btn_play"
                    app:layout_constraintBottom_toBottomOf="@id/btn_play"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </FrameLayout>

        <!-- RIGHT PANEL: TRACK LIST (60%) -->
        <LinearLayout
            android:id="@+id/track_list_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="6"
            android:orientation="vertical"
            android:background="@android:color/transparent"
            android:padding="8dp">

            <!-- Hybrid Tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_rounded_black"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tab_all_tracks"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Tum Sarkilar"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="?android:attr/selectableItemBackground"/>
                
                <View android:layout_width="1dp" android:layout_height="24dp" android:background="#444444"/>

                <TextView
                    android:id="@+id/tab_recent"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Son Calinan"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="?android:attr/selectableItemBackground"/>

                <View android:layout_width="1dp" android:layout_height="24dp" android:background="#444444"/>

                <!-- Playlist Tab with Spinner -->
                <LinearLayout
                    android:id="@+id/tab_playlists_container"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.5"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="?android:attr/selectableItemBackground"
                    android:paddingStart="8dp">
                    
                    <TextView
                        android:id="@+id/tab_playlist_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Listeler: "
                        android:textColor="#888888"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <Spinner
                        android:id="@+id/playlist_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:spinnerMode="dropdown"/>
                </LinearLayout>
            </LinearLayout>
            
            <!-- Search Bar -->
            <EditText
                android:id="@+id/search_input"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/bg_widget_card"
                android:hint="Ara..."
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:textSize="14sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:singleLine="true"
                android:imeOptions="actionSearch"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawableTint="#888888"
                android:drawablePadding="8dp"
                android:layout_marginBottom="8dp"/>

            <!-- List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/music_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scrollbars="vertical"
                android:clipToPadding="false"
                android:paddingBottom="16dp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
