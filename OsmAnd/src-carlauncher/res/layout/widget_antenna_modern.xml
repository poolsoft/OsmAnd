<?xml version="1.0" encoding="utf-8"?>
<!-- Anten Hizalama Widget — Her zaman acik kompakt layout -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_widget_modern"
    android:padding="10dp">

    <!-- Baslik Satiri -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_compass"
            android:tint="#EEE"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="8dp"
            android:text="ANTEN HIZALAMA"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <!-- Hizalama penceresi acma butonu -->
        <ImageButton
            android:id="@+id/btn_align"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_circle_translucent_white"
            android:src="@android:drawable/ic_menu_compass"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:tint="#FF6D00"
            android:contentDescription="Hizalamayi Baslat"/>
    </LinearLayout>

    <!-- Kaynak / Hedef satiri -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="6dp">

        <!-- KAYNAK -->
        <LinearLayout
            android:id="@+id/btn_set_source"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded_black"
            android:padding="8dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KAYNAK"
                android:textColor="#4FC3F7"
                android:textSize="9sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/text_source"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sec..."
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Swap Butonu (iki nokta secilince aktif olur) -->
        <ImageButton
            android:id="@+id/btn_swap"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:tint="#555555"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:contentDescription="Kaynak-Hedef Degistir"/>

        <!-- HEDEF -->
        <LinearLayout
            android:id="@+id/btn_set_target"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded_black"
            android:padding="8dp"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HEDEF"
                android:textColor="#FFD700"
                android:textSize="9sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/text_target"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sec..."
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Hesaplama degerleri (nokta secildiyse goster) -->
    <LinearLayout
        android:id="@+id/stats_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">

        <!-- Azimut -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/val_azimuth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textColor="#FFD700"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Azimut"
                android:textColor="#888888"
                android:textSize="9sp"/>
        </LinearLayout>

        <!-- Mesafe -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/val_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mesafe"
                android:textColor="#888888"
                android:textSize="9sp"/>
        </LinearLayout>

        <!-- Pitch / Egim -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/val_elevation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Egim"
                android:textColor="#888888"
                android:textSize="9sp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
