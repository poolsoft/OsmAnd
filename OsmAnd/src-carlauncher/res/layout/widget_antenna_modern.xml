<?xml version="1.0" encoding="utf-8"?>
<!-- Anten Hizalama Widget — Modern Glassmorphism Tasarimi -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="130dp"
    android:orientation="vertical"
    android:background="@drawable/bg_widget_modern"
    android:padding="12dp">

    <!-- Baslik Satiri -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/ic_menu_compass"
            android:tint="@color/cl_text_secondary"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="8dp"
            android:text="ANTEN HIZALAMA"
            style="@style/CarWidget.Title"/>

        <!-- Harita katmani toggle -->
        <ImageButton
            android:id="@+id/btn_layer_toggle"
            style="@style/CarWidget.Button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_view"
            android:tint="@color/cl_text_hint"
            android:contentDescription="Katman"/>

    </LinearLayout>

    <!-- Kaynak / Hedef Secimi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:id="@+id/btn_set_source"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="@drawable/ripple_bg"
            android:clickable="true"
            android:focusable="true">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KAYNAK"
                style="@style/CarWidget.Title"
                android:textSize="10sp"/>
            
            <TextView
                android:id="@+id/text_source"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sec..."
                android:textColor="@color/cl_primary"
                android:textStyle="bold"
                android:textSize="14sp"
                android:ellipsize="end"
                android:maxLines="1"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_swap"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="@color/cl_text_hint"
            android:padding="10dp"
            android:scaleType="fitCenter"/>

        <LinearLayout
            android:id="@+id/btn_set_target"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="@drawable/ripple_bg"
            android:clickable="true"
            android:focusable="true">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HEDEF"
                style="@style/CarWidget.Title"
                android:textSize="10sp"/>
            
            <TextView
                android:id="@+id/text_target"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sec..."
                android:textColor="@color/cl_accent_gold"
                android:textStyle="bold"
                android:textSize="14sp"
                android:ellipsize="end"
                android:maxLines="1"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Bilgi Paneli (Mesafe / Azimut / Pitch) -->
    <LinearLayout
        android:id="@+id/stats_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="12dp"
        android:visibility="visible">

        <!-- Mesafe -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:text="MESAFE" style="@style/CarWidget.Title" android:textSize="10sp"/>
            <TextView android:id="@+id/val_distance" android:text="0.0 km" style="@style/CarWidget.Value" android:textSize="18sp"/>
        </LinearLayout>

        <!-- Azimut -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:text="AZIMUT" style="@style/CarWidget.Title" android:textSize="10sp"/>
            <TextView android:id="@+id/val_azimuth" android:text="0.0°" style="@style/CarWidget.Value" android:textSize="18sp" android:textColor="@color/cl_accent_gold"/>
        </LinearLayout>

        <!-- Pitch -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:text="PITCH" style="@style/CarWidget.Title" android:textSize="10sp"/>
            <TextView android:id="@+id/val_elevation" android:text="0.0°" style="@style/CarWidget.Value" android:textSize="18sp" android:textColor="@color/cl_success"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Hizalama Ekrani Butonu -->
    <Button
        android:id="@+id/btn_align"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:text="ANTENİ HIZALA"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_circle_button"
        android:backgroundTint="@color/cl_accent_orange"
        android:textSize="12sp"
        android:textStyle="bold"
        android:elevation="2dp"/>
</LinearLayout>
