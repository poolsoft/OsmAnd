<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6000000"
    android:clickable="true"
    android:focusable="true"
    android:padding="@dimen/weather_padding">

    <!-- Header -->
    <TextView
        android:id="@+id/tv_location"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Location"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/weather_location_text_size"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btn_close"/>

    <ImageButton
        android:id="@+id/btn_close"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Current Weather -->
    <LinearLayout
        android:id="@+id/current_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_location">

        <ImageView
            android:id="@+id/img_current_icon"
            android:layout_width="@dimen/weather_icon_size"
            android:layout_height="@dimen/weather_icon_size"
            android:src="@drawable/ic_weather_cloudy"/>

        <TextView
            android:id="@+id/tv_current_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="24°"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/weather_temp_text_size"
            android:textStyle="bold"
            android:layout_marginStart="16dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">
            
            <TextView
                android:id="@+id/tv_current_condition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cloudy"
                android:textColor="#E0E0E0"
                android:textSize="@dimen/weather_condition_text_size"/>

            <TextView
                 android:id="@+id/tv_apparent_temp"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:text="Feels 26°"
                 android:textColor="#AAAAAA"
                 android:textSize="@dimen/weather_feels_text_size"/>

        </LinearLayout>
    </LinearLayout>

    <!-- Details Grid -->
    <LinearLayout
        android:id="@+id/details_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/current_container">

        <!-- Wind -->
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
             <ImageView android:layout_width="@dimen/weather_detail_icon_size" android:layout_height="@dimen/weather_detail_icon_size" android:src="@drawable/ic_action_direction" android:tint="#AAAAAA"/>
             <TextView android:id="@+id/tv_wind" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15 km/h" android:textColor="#FFFFFF"/>
             <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wind" android:textColor="#AAAAAA" android:textSize="10sp"/>
        </LinearLayout>

        <!-- Rain -->
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
             <ImageView android:layout_width="@dimen/weather_detail_icon_size" android:layout_height="@dimen/weather_detail_icon_size" android:src="@drawable/ic_weather_rain" android:tint="#AAAAAA"/>
             <TextView android:id="@+id/tv_rain" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10%" android:textColor="#FFFFFF"/>
             <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rain" android:textColor="#AAAAAA" android:textSize="10sp"/>
        </LinearLayout>

        <!-- Visibility -->
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
             <ImageView android:layout_width="@dimen/weather_detail_icon_size" android:layout_height="@dimen/weather_detail_icon_size" android:src="@drawable/ic_action_view" android:tint="#AAAAAA"/>
             <TextView android:id="@+id/tv_visibility" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10 km" android:textColor="#FFFFFF"/>
             <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Visibility" android:textColor="#AAAAAA" android:textSize="10sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Hourly List -->
    <TextView
        android:id="@+id/lbl_hourly"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hourly Forecast"
        android:textColor="#AAAAAA"
        android:textSize="@dimen/weather_section_label_text_size"
        android:layout_marginTop="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/details_container"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_hourly"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/lbl_hourly"/>

    <!-- Daily List -->
    <TextView
        android:id="@+id/lbl_daily"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daily Forecast"
        android:textColor="#AAAAAA"
        android:textSize="@dimen/weather_section_label_text_size"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rv_hourly"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_daily"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/lbl_daily"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
