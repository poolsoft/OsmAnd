<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6000000"
    android:clickable="true"
    android:focusable="true"
    android:padding="16dp">

    <!-- Header: Location & Close -->
    <TextView
        android:id="@+id/tv_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Location"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <ImageButton
        android:id="@+id/btn_close"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Left Pane: Stats -->
    <LinearLayout
        android:id="@+id/left_pane"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_vertical"
        app:layout_constraintWidth_percent="0.3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_location"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout android:orientation="horizontal" android:gravity="center_vertical">
            <ImageView
                android:id="@+id/img_current_icon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_weather_cloudy"/>
            <TextView
                android:id="@+id/tv_current_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24°"
                android:textColor="#FFFFFF"
                android:textSize="56sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_current_condition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cloudy"
            android:textColor="#E0E0E0"
            android:textSize="18sp"
            android:layout_marginTop="4dp"/>

        <TextView
             android:id="@+id/tv_apparent_temp"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:text="Feels 26°"
             android:textColor="#AAAAAA"
             android:textSize="16sp"
             android:layout_marginTop="4dp"/>

        <!-- Details Grid Vertical List -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="24dp">
            <TextView android:id="@+id/tv_wind" android:text="Wind: 15 km/h" android:textColor="#FFFFFF" android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tv_rain" android:text="Rain: 10%" android:textColor="#FFFFFF" android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tv_visibility" android:text="Vis: 10 km" android:textColor="#FFFFFF"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Right Pane: Graph & Daily -->
    <LinearLayout
        android:id="@+id/right_pane"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        app:layout_constraintStart_toEndOf="@+id/left_pane"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_close"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Graph Area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            
            <net.osmand.plus.carlauncher.widgets.view.TrendGraphView
                android:id="@+id/trend_graph"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_hourly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:background="#44000000"
                android:orientation="horizontal"/>
        </FrameLayout>

        <!-- Daily Forecast Horizontal for Landscape -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="7-Day Forecast"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginTop="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_daily"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
