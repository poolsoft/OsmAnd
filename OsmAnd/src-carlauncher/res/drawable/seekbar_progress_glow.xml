<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Arka plan cizgisi -->
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="4dp" />
            <solid android:color="#222222" />
        </shape>
    </item>
    <!-- Ilerleme cizgisi -->
    <item android:id="@android:id/progress">
        <clip>
            <layer-list>
                <!-- Dis glow katmani -->
                <item android:id="@+id/seekbar_glow_progress" android:top="0dp" android:bottom="0dp">
                    <shape>
                        <corners android:radius="4dp" />
                        <solid android:color="#3300FFFF" />
                    </shape>
                </item>
                <!-- Ana parlak progress -->
                <item android:id="@+id/seekbar_main_progress" android:top="2dp" android:bottom="2dp">
                    <shape>
                        <corners android:radius="4dp" />
                        <solid android:color="#00FFFF" />
                    </shape>
                </item>
            </layer-list>
        </clip>
    </item>
</layer-list>
