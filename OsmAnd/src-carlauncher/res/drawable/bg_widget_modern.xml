<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Katman 1: Ana Koyu Cam Arka Plan -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/cl_surface_overlay"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <!-- Katman 2: Üstten Gelen Hafif Parlama (Gradient) -->
    <item android:bottom="40dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#15FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270"
                android:type="linear"/>
            <corners 
                android:topLeftRadius="16dp" 
                android:topRightRadius="16dp"/>
        </shape>
    </item>

    <!-- Katman 3: İnce Beyaz Kenar Çizgisi (Border) -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="@color/cl_border"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
</layer-list>
