<?xml version="1.0" encoding="utf-8"?>
<!-- Widget arka plani — API 27 uyumlu glassmorphism simülasyonu.
     Blur efekti yok, bunun yerine katmanli renk ve kenari kullaniyoruz. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Katman 1: Ana koyu arka plan (%80 opak) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/cl_bg_overlay"/>
            <corners android:radius="@dimen/widget_corner_radius"/>
        </shape>
    </item>

    <!-- Katman 2: Üst yarida hafif parlak gradient (cam yansimasi hissi) -->
    <item
        android:bottom="60%">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/cl_highlight_top"
                android:endColor="#00000000"
                android:angle="270"
                android:type="linear"/>
            <corners
                android:topLeftRadius="@dimen/widget_corner_radius"
                android:topRightRadius="@dimen/widget_corner_radius"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp"/>
        </shape>
    </item>

    <!-- Katman 3: Ince kenar cizgisi (cam kenari hissi) -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="@color/cl_border"/>
            <corners android:radius="@dimen/widget_corner_radius"/>
        </shape>
    </item>

</layer-list>
