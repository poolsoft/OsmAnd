<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dis glow halkasi -->
    <item android:id="@+id/seekbar_thumb_glow_layer" android:top="0dp" android:bottom="0dp" android:left="0dp" android:right="0dp">
        <shape android:shape="oval">
            <solid android:color="#3300FFFF" />
            <stroke android:width="3dp" android:color="#8800FFFF" />
            <size android:width="24dp" android:height="24dp" />
        </shape>
    </item>
    <!-- Ic parlayan thumb daire -->
    <item android:id="@+id/seekbar_thumb_main_layer" android:top="6dp" android:bottom="6dp" android:left="6dp" android:right="6dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>
