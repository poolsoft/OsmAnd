<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Ana Widget Stili (Ebeveyn) -->
    <style name="CarWidget">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <!-- Widget Başlık Stili -->
    <style name="CarWidget.Title" parent="CarWidget">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/cl_text_secondary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Widget Değer Stili -->
    <style name="CarWidget.Value" parent="CarWidget">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/cl_text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Widget Birim Stili -->
    <style name="CarWidget.Unit" parent="CarWidget">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/cl_text_secondary</item>
        <item name="android:layout_marginStart">4dp</item>
    </style>

    <!-- Araba Buton Stili -->
    <style name="CarWidget.Button" parent="CarWidget">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:padding">12dp</item>
        <item name="android:scaleType">fitCenter</item>
    </style>
    <!-- Antenna Alignment HUD Theme -->
    <style name="Theme.HUD" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>
