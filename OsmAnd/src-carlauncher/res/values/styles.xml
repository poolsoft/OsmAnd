<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Widget Başlık Stili (Küçük ve Şık) -->
    <style name="CarWidget.Title">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/cl_text_secondary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Widget Değer Stili (Büyük ve Okunaklı) -->
    <style name="CarWidget.Value">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/cl_text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Widget Birim Stili (örn: km/h) -->
    <style name="CarWidget.Unit">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/cl_text_secondary</item>
        <item name="android:layout_marginStart">4dp</item>
    </style>

    <!-- Araba Buton Stili (Geniş Dokunma Alanı) -->
    <style name="CarWidget.Button">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:padding">12dp</item>
        <item name="android:scaleType">fitCenter</item>
    </style>
</resources>
