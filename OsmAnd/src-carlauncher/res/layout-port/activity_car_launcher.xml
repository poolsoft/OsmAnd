<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false"
    android:clipChildren="false">

    <!-- MAP CONTAINER (Weight 3 - %75 height) -->
    <net.osmand.plus.carlauncher.ui.ExactFrameLayout
        android:id="@+id/map_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_card_rounded_black" 
        android:clipToOutline="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/widget_panel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_weight="3"
        android:elevation="4dp"/>

    <!-- WIDGET PANEL (Weight 1 - %25 height) - Reduced Size -->
    <FrameLayout
        android:id="@+id/widget_panel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@+id/map_container"
        app:layout_constraintBottom_toTopOf="@+id/app_dock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_weight="1" />

    <!-- WIDGET HANDLE (Constraint'ler Java tarafindan yonetilir) -->
    <ImageButton
        android:id="@+id/widget_handle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_chevron_left"
        android:background="@drawable/bg_drawer_handle"
        android:scaleType="fitCenter"
        android:padding="16dp"
        android:elevation="25dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- APP DOCK -->
    <FrameLayout
        android:id="@+id/app_dock"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:background="#000000"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
    </FrameLayout>

    <!-- APP DRAWER OVERLAY -->
    <FrameLayout
        android:id="@+id/app_drawer_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#DD000000"
        android:visibility="gone"
        android:paddingTop="0dp"
        android:elevation="20dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />



    <!-- NIGHT DIM OVERLAY (Gece Karartma Katmani - Turkce karakter yok) -->
    <View
        android:id="@+id/night_dim_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone"
        android:elevation="100dp"
        android:clickable="false"
        android:focusable="false"/>

</androidx.constraintlayout.widget.ConstraintLayout>
